{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "Ant Browser",
  "outputfilename": "ant-chrome",
  "frontend:install": "npx cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 npm ci --prefer-offline --no-audit --no-fund && npm run ensure:native",
  "frontend:build": "npm run build",
  "author": {
    "name": "Ant Chrome Team",
    "email": "contact@antblack.de"
  },
  "info": {
    "companyName": "Ant Chrome",
    "productName": "Ant Browser",
    "productVersion": "1.1.0",
    "copyright": "Copyright © 2026",
    "comments": "面向多账号隔离、代理绑定和本地环境管理的桌面浏览器工具"
  },
  "nsisType": "multiple",
  "obfuscated": false,
  "wailsjsdir": "./frontend/src"
}
